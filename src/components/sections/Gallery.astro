---
/**
 * Gallery — an asymmetric editorial grid of atmosphere/detail placeholders.
 * Doubles as the "Instagram" moment: a link out to the salon's feed.
 */
import Section from '@ui/Section.astro';
import SectionHeading from '@ui/SectionHeading.astro';
import Reveal from '@ui/Reveal.astro';
import Figure from '@ui/Figure.astro';
import { gallery } from '@data/content';
import { socials } from '@data/site';

const instagram = socials.find((s) => s.label === 'Instagram');

// Map span hints to grid placement for the asymmetric editorial layout.
// Fixed row height + fill figures avoid aspect-ratio blowing past the grid.
const spanClass = {
  tall: 'row-span-2',
  wide: 'col-span-2',
  square: '',
} as const;

// `sizes` describes the rendered *width*, but a `tall` tile is one column wide
// and two rows high — object-cover then scales by height, so it needs a bigger
// candidate than its column width suggests. Overstate the hint accordingly.
const sizeHint = {
  tall: '(min-width: 640px) 60vw, 100vw',
  wide: '(min-width: 640px) 66vw, 100vw',
  square: '(min-width: 640px) 33vw, 50vw',
} as const;
---

<Section id="gallery" tone="espresso" space="lg" width="wide">
  <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
    <SectionHeading
      eyebrow="Атмосфера"
      heading="Простір, у якому хочеться затриматися"
      onDark
      id="gallery-heading"
    />
    {
      instagram && (
        <a
          href={instagram.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 self-start text-sm font-medium text-porcelain/80 transition-colors hover:text-porcelain md:self-auto"
        >
          Стежити в Instagram · {instagram.handle}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 17L17 7M17 7H9M17 7v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      )
    }
  </div>

  <!--
    Row height tracks column width (container query units), so a `square` tile
    stays 1/1 and a `wide` one stays 2/1 at every viewport. With a fixed row
    height the columns keep growing while the rows don't, and on large screens
    the tiles flatten until the crop eats the subject of the photo.
  -->
  <div class="@container mt-12">
    <div
      class="grid auto-rows-[calc((100cqw-1rem)/2)] grid-cols-2 gap-4 sm:auto-rows-[calc((100cqw-2rem)/3)] sm:grid-cols-3 lg:auto-rows-[calc((100cqw-2.5rem)/3)] lg:gap-5"
    >
      {
        gallery.map((item, i) => (
          <Reveal delay={(i % 3) * 80} class={`${spanClass[item.span]} min-h-0`}>
            <Figure
              src={item.image}
              alt={item.alt}
              caption={item.caption}
              monogram=""
              fill
              widths={[320, 480, 720, 1024]}
              sizes={sizeHint[item.span]}
              class="brightness-[1.02]"
            />
          </Reveal>
        ))
      }
    </div>
  </div>
</Section>
