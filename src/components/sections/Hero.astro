---
/**
 * Hero — AIDA: Attention.
 * Outcome-led headline (not a service list), one calm subheadline, a single
 * primary CTA, and quiet social proof. The still portrait is the LCP element,
 * so it loads eagerly; the 15–20s WebM cinemagraph from the research can later
 * be layered over it without touching the layout.
 */
import { Image } from 'astro:assets';
import Container from '@ui/Container.astro';
import Button from '@ui/Button.astro';
import heroImage from '@/assets/hero.webp';
import { site, availabilityNote } from '@data/site';
---

<section id="top" class="relative overflow-hidden bg-canvas pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Ambient, GPU-cheap gradient wash standing in for the hero cinemagraph. -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -right-32 -top-24 h-[38rem] w-[38rem] rounded-full bg-[radial-gradient(circle,oklch(88%_0.04_290/0.55),transparent_65%)] blur-2xl"></div>
    <div class="absolute -left-40 top-1/3 h-[34rem] w-[34rem] rounded-full bg-[radial-gradient(circle,oklch(62%_0.08_65/0.32),transparent_65%)] blur-2xl"></div>
  </div>

  <Container width="wide">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
      <!-- Copy column -->
      <div class="max-w-2xl">
        <p data-reveal class="eyebrow mb-6">Салон краси · Львів · вул. Вірменська</p>

        <h1
          data-reveal
          style="--reveal-delay:80ms"
          class="text-balance font-display text-[clamp(2.6rem,1.8rem+3.4vw,4.4rem)] font-light leading-[1.04] tracking-[-0.02em] text-ink"
        >
          Справжня краса
          <span class="italic text-mocha-deep">народжується</span>
          зі спокою
        </h1>

        <p
          data-reveal
          style="--reveal-delay:160ms"
          class="mt-7 max-w-xl text-lg leading-relaxed text-stone"
        >
          {site.name} — простір догляду в центрі Львова, де вами опікується
          один майстер, а кожна процедура починається з уваги до вас, а не з поспіху.
        </p>

        <div data-reveal style="--reveal-delay:240ms" class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
          <Button href="#booking" size="lg">Підібрати час візиту</Button>
          <Button href="#services" variant="ghost" size="lg">
            Переглянути послуги
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </Button>
        </div>

        <!-- Quiet social proof + soft availability (no aggressive urgency). -->
        <div data-reveal style="--reveal-delay:320ms" class="mt-12 flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-8">
          <div class="flex items-center gap-3">
            <div class="flex text-mocha" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.5l2.9 6.1 6.6.8-4.9 4.6 1.3 6.6L12 18.9 6.1 21.2l1.3-6.6L2.5 9.9l6.6-.8z" /></svg>
              ))}
            </div>
            <p class="text-sm text-stone">
              <span class="font-medium text-ink">4.9</span> · відгуки гостей у Google
            </p>
          </div>
          <p class="flex items-center gap-2 text-sm text-stone">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-olive" aria-hidden="true"></span>
            {availabilityNote}
          </p>
        </div>
      </div>

      <!-- Media column: layered editorial placeholders. -->
      <div data-reveal style="--reveal-delay:200ms" class="relative">
        <div class="placeholder-media aspect-[4/5] rounded-2xl2 shadow-lift">
          <Image
            src={heroImage}
            alt="Інтерʼєр салону VERVENA у теплому денному світлі: майстер за роботою в спокійній атмосфері"
            widths={[480, 720, 960, 1200]}
            sizes="(min-width: 1024px) 44vw, (min-width: 640px) 70vw, 100vw"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover"
          />
        </div>

        <!-- Floating detail card — depth without clutter. -->
        <div class="absolute -bottom-6 -left-6 hidden max-w-[15rem] rounded-2xl2 bg-porcelain/90 p-5 shadow-lift backdrop-blur-sm sm:block">
          <p class="eyebrow mb-1.5">Ритуал</p>
          <p class="text-sm leading-relaxed text-ink">
            Один гість у робочу годину — простір, у якому нікуди поспішати.
          </p>
        </div>
      </div>
    </div>
  </Container>

  <!-- Sentinel: header/sticky-CTA switch state once this scrolls out of view. -->
  <div data-hero-sentinel aria-hidden="true" class="absolute bottom-0 h-px w-full"></div>
</section>
