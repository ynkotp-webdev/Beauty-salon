---
/**
 * Services — AIDA: Desire.
 * Care directions as large, softly-bordered cards. Prices are shown openly as
 * "від {sum} ₴" with durations, so clients can plan without contacting us —
 * hiding prices is flagged as a critical conversion error in the research.
 */
import Section from '@ui/Section.astro';
import SectionHeading from '@ui/SectionHeading.astro';
import Reveal from '@ui/Reveal.astro';
import { serviceCategories, currency } from '@data/services';

const accentClass = {
  mocha: 'text-mocha-deep bg-mocha/10',
  olive: 'text-olive bg-olive/10',
  lavender: 'text-[oklch(45%_0.06_290)] bg-lavender/25',
} as const;
---

<Section id="services" tone="canvas" space="lg">
  <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
    <SectionHeading
      eyebrow="Меню процедур"
      heading="Догляд, дібраний саме для вас"
      intro="Ми думаємо категоріями турботи, а не переліком маніпуляцій. Оберіть напрям — решту підкаже майстер на консультації."
      id="services-heading"
    />
    <p class="text-sm text-stone md:text-right md:max-w-[16rem]">
      Ціни вказані «від» — фінальну вартість майстер називає до початку роботи.
    </p>
  </div>

  <div class="mt-14 grid gap-6 lg:grid-cols-2">
    {
      serviceCategories.map((cat, i) => (
        <Reveal
          delay={(i % 2) * 90}
          as="article"
          class="group flex flex-col rounded-2xl2 border border-mist bg-porcelain p-7 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:border-mocha/30 hover:shadow-lift sm:p-9"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class={`inline-block rounded-full px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.12em] ${accentClass[cat.accent]}`}>
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="mt-4 font-display text-2xl font-normal text-ink">{cat.title}</h3>
              <p class="mt-2 max-w-md text-[0.95rem] leading-relaxed text-stone">{cat.summary}</p>
            </div>
          </div>

          <ul class="mt-7 flex flex-col divide-y divide-mist/80 border-t border-mist/80">
            {cat.items.map((item) => (
              <li class="flex items-baseline justify-between gap-5 py-4">
                <div class="min-w-0">
                  <p class="font-medium text-ink">{item.name}</p>
                  {item.note && <p class="mt-0.5 text-sm text-stone">{item.note}</p>}
                </div>
                <div class="shrink-0 text-right">
                  <p class="whitespace-nowrap font-display text-lg text-ink">
                    від {item.priceFrom.toLocaleString('uk-UA')}&nbsp;{currency}
                  </p>
                  <p class="text-xs uppercase tracking-wide text-stone">{item.duration}</p>
                </div>
              </li>
            ))}
          </ul>

          <a
            href="#booking"
            class="mt-7 inline-flex items-center gap-2 self-start text-sm font-medium text-mocha-deep transition-colors hover:text-ink"
          >
            Записатися на {cat.title.toLowerCase()}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </Reveal>
      ))
    }
  </div>
</Section>
