---
/**
 * Testimonials — social proof with attribution and a verification-style source
 * tag. Believable, restrained voices — no inflated ratings or client counts.
 */
import Section from '@ui/Section.astro';
import SectionHeading from '@ui/SectionHeading.astro';
import Reveal from '@ui/Reveal.astro';
import { testimonials } from '@data/content';
---

<Section id="reviews" tone="canvas" space="lg" width="wide">
  <SectionHeading
    eyebrow="Відгуки гостей"
    heading="Те, що залишається після візиту"
    intro="Кілька чесних вражень наших гостей. Ми не вигадуємо цифр — цінуємо реальні слова."
    id="reviews-heading"
    class="mb-14"
  />

  <ul class="grid gap-6 md:grid-cols-2">
    {
      testimonials.map((t, i) => (
        <Reveal as="li" delay={(i % 2) * 90} class="h-full">
          <figure class="flex h-full flex-col rounded-2xl2 border border-mist bg-porcelain p-8 sm:p-9">
            <div class="flex text-mocha" aria-label="Оцінка: 5 з 5">
              {Array.from({ length: 5 }).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.5l2.9 6.1 6.6.8-4.9 4.6 1.3 6.6L12 18.9 6.1 21.2l1.3-6.6L2.5 9.9l6.6-.8z" /></svg>
              ))}
            </div>
            <blockquote class="mt-5 flex-1">
              <p class="font-display text-lg font-light leading-relaxed text-ink">«{t.quote}»</p>
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3 border-t border-mist pt-5">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-sand font-display text-lg text-mocha-deep" aria-hidden="true">
                {t.author.charAt(0)}
              </span>
              <span class="min-w-0">
                <span class="block font-medium text-ink">{t.author}</span>
                <span class="block text-sm text-stone">
                  {t.meta} · <span class="text-olive">Підтверджено · {t.source}</span>
                </span>
              </span>
            </figcaption>
          </figure>
        </Reveal>
      ))
    }
  </ul>
</Section>
