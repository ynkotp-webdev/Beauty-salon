---
/**
 * Specialists — AIDA: Trust & Authority.
 * In premium beauty, clients book a person. Each master gets a portrait,
 * a clear specialisation, an honest note on their approach and a direct
 * booking link — no invented years-of-experience.
 */
import Section from '@ui/Section.astro';
import SectionHeading from '@ui/SectionHeading.astro';
import Reveal from '@ui/Reveal.astro';
import Figure from '@ui/Figure.astro';
import { specialists } from '@data/specialists';
---

<Section id="specialists" tone="linen" space="lg" width="wide">
  <SectionHeading
    eyebrow="Наші майстри"
    heading="Люди, яким ви довіряєте себе"
    intro="Кожен майстер VERVENA має власний почерк і напрям. Оберіть того, чий підхід відгукується вам."
    id="specialists-heading"
    class="mb-14"
  />

  <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      specialists.map((person, i) => (
        <Reveal as="li" delay={(i % 3) * 90} class="group flex flex-col">
          <div class="relative overflow-hidden rounded-2xl2">
            <Figure
              src={person.portrait}
              alt={person.portraitAlt}
              ratio="4/5"
              monogram={person.name.charAt(0)}
              widths={[320, 480, 640, 960]}
              sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 100vw"
              class="transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
            />
          </div>

          <div class="mt-5 flex flex-1 flex-col">
            <h3 class="font-display text-xl font-normal text-ink">{person.name}</h3>
            <p class="mt-1 text-sm font-medium uppercase tracking-[0.08em] text-mocha-deep">
              {person.role}
            </p>
            <p class="mt-3 text-[0.95rem] leading-relaxed text-stone">{person.focus}</p>

            <ul class="mt-4 flex flex-wrap gap-2">
              {person.areas.map((area) => (
                <li class="rounded-full bg-sand px-3 py-1 text-xs font-medium text-ink/70">{area}</li>
              ))}
            </ul>

            <a
              href="#booking"
              class="mt-5 inline-flex items-center gap-2 self-start text-sm font-medium text-ink transition-colors hover:text-mocha-deep"
            >
              Записатися до {person.name.split(' ')[0]}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </Reveal>
      ))
    }
  </ul>
</Section>
