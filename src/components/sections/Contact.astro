---
/**
 * Contact — AIDA: Action support. Location, hours and one-tap route/call.
 * A lightweight stylised map stands in for a heavy embedded iframe (kept off
 * the critical path); the button opens the real route in one click.
 */
import Section from '@ui/Section.astro';
import SectionHeading from '@ui/SectionHeading.astro';
import Reveal from '@ui/Reveal.astro';
import Button from '@ui/Button.astro';
import { contact, openingHours } from '@data/site';
---

<Section id="contact" tone="canvas" space="lg" width="wide">
  <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
    <!-- Details -->
    <div>
      <SectionHeading
        eyebrow="Як нас знайти"
        heading="У серці старого Львова"
        intro="Салон розташований на затишній вулиці Вірменській, за кілька кроків від площі Ринок."
        id="contact-heading"
      />

      <dl class="mt-10 grid gap-8 sm:grid-cols-2">
        <Reveal as="div">
          <dt class="eyebrow mb-2">Адреса</dt>
          <dd class="text-lg text-ink">
            {contact.street}<br />
            {contact.city}, {contact.postcode}
          </dd>
        </Reveal>
        <Reveal as="div" delay={70}>
          <dt class="eyebrow mb-2">Контакти</dt>
          <dd class="flex flex-col gap-1 text-lg">
            <a href={contact.phoneHref} class="text-ink transition-colors hover:text-mocha-deep">{contact.phoneDisplay}</a>
            <a href={contact.emailHref} class="text-ink transition-colors hover:text-mocha-deep">{contact.email}</a>
          </dd>
        </Reveal>
        <Reveal as="div" delay={140} class="sm:col-span-2">
          <dt class="eyebrow mb-3">Графік роботи</dt>
          <dd>
            <ul class="flex flex-col divide-y divide-mist border-y border-mist">
              {openingHours.map((o) => (
                <li class="flex items-center justify-between py-3">
                  <span class="text-ink">{o.day}</span>
                  <span class="font-medium text-stone">{o.hours}</span>
                </li>
              ))}
            </ul>
          </dd>
        </Reveal>
      </dl>

      <div class="mt-9">
        <Button href={contact.mapUrl} variant="secondary" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21s7-6.2 7-11a7 7 0 10-14 0c0 4.8 7 11 7 11z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
            <circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.5" />
          </svg>
          Прокласти маршрут
        </Button>
      </div>
    </div>

    <!-- Stylised map placeholder -->
    <Reveal class="min-h-[22rem]">
      <a
        href={contact.mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative flex h-full min-h-[22rem] items-center justify-center overflow-hidden rounded-2xl2 border border-mist shadow-soft"
        aria-label="Відкрити розташування салону VERVENA на мапі Google"
      >
        <!-- Abstract street grid -->
        <div class="absolute inset-0 bg-linen" aria-hidden="true">
          <svg class="h-full w-full text-mist" viewBox="0 0 400 300" fill="none" preserveAspectRatio="xMidYMid slice">
            <g stroke="currentColor" stroke-width="6">
              <path d="M-20 90h440M-20 200h440M80 -20v340M250 -20v340" opacity="0.5" />
              <path d="M-20 40l440 220" opacity="0.25" />
            </g>
            <rect x="120" y="110" width="70" height="60" fill="currentColor" opacity="0.25" />
            <rect x="270" y="130" width="60" height="50" fill="currentColor" opacity="0.2" />
          </svg>
        </div>
        <!-- Pin -->
        <div class="relative z-10 flex flex-col items-center gap-3 text-center">
          <span class="flex h-14 w-14 items-center justify-center rounded-full bg-mocha text-porcelain shadow-lift transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-1">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 21s7-6.2 7-11a7 7 0 10-14 0c0 4.8 7 11 7 11z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
              <circle cx="12" cy="10" r="2.4" fill="currentColor" />
            </svg>
          </span>
          <span class="rounded-full bg-porcelain/90 px-4 py-1.5 text-sm font-medium text-ink shadow-soft backdrop-blur-sm">
            {contact.street}
          </span>
        </div>
      </a>
    </Reveal>
  </div>
</Section>
