---
/**
 * Results — AIDA: Desire.
 * Accessible before/after comparison (drag, click, full keyboard control via
 * the WAI-ARIA slider pattern — see scripts/before-after.ts).
 */
import { Image } from 'astro:assets';
import Section from '@ui/Section.astro';
import SectionHeading from '@ui/SectionHeading.astro';
import Reveal from '@ui/Reveal.astro';
import beforeImage from '@/assets/results-before.jpg';
import afterImage from '@/assets/results-after.jpg';

// Both frames are shot identically, so they share one srcset recipe — any
// mismatch in rendered size would break the illusion of a single photograph.
const frameWidths = [640, 960, 1280, 1600];
const frameSizes = '(min-width: 1024px) 56rem, 100vw';
---

<Section id="results" tone="canvas" space="lg">
  <SectionHeading
    eyebrow="Результати"
    heading="Зміни, які видно й приємно торкнутися"
    intro="Пересувайте роздільник, щоб порівняти стан до та після догляду. Керується мишею, дотиком або клавішами-стрілками."
    align="center"
    id="results-heading"
    class="mb-12"
  />

  <Reveal class="mx-auto max-w-4xl">
    <div
      data-before-after
      class="relative aspect-[16/10] w-full select-none overflow-hidden rounded-2xl2 shadow-lift"
      role="group"
      aria-label="Порівняння результату догляду за обличчям: до та після"
    >
      <!-- AFTER (base layer) -->
      <div class="placeholder-media absolute inset-0">
        <Image
          src={afterImage}
          alt="Після догляду: рівний тон, природне сяйво, доглянута шкіра"
          widths={frameWidths}
          sizes={frameSizes}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <span class="absolute bottom-4 right-4 z-10 rounded-full bg-porcelain/85 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-ink">Після</span>
      </div>

      <!-- BEFORE (clipped top layer) -->
      <div
        data-before
        class="placeholder-media absolute inset-0"
        style="clip-path: inset(0 50% 0 0);"
      >
        <Image
          src={beforeImage}
          alt="До догляду: тьмяний тон, нерівна текстура шкіри"
          widths={frameWidths}
          sizes={frameSizes}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <span class="absolute bottom-4 left-4 z-10 rounded-full bg-espresso/60 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-porcelain">До</span>
      </div>

      <!-- Divider handle -->
      <div
        data-handle
        class="absolute top-0 bottom-0 z-10 -ml-0.5 w-1 cursor-ew-resize bg-porcelain shadow-[0_0_0_1px_oklch(26%_0.02_60/0.15)]"
        style="left: 50%;"
        role="slider"
        tabindex="0"
        aria-label="Роздільник порівняння"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
        aria-valuetext="50% — рівно посередині"
      >
        <span class="absolute left-1/2 top-1/2 flex h-11 w-11 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-porcelain shadow-lift">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-mocha-deep">
            <path d="M9 7l-4 5 4 5M15 7l4 5-4 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
      </div>
    </div>
    <p class="mt-4 text-center text-sm text-stone">
      Ілюстративне порівняння. Реальні результати індивідуальні та залежать від стану шкіри.
    </p>
  </Reveal>
</Section>
